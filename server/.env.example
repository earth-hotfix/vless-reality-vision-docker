# VLESS + Reality + Vision Server Configuration

# Listening port (default: 443 for TLS camouflage)
XRAY_PORT=443

# VLESS user UUID — generate with: bash ../scripts/gen-uuid.sh
UUID=your-uuid-here

# Reality SNI domain — must be a real TLS 1.3 site reachable from your server
SNI_DOMAIN=www.microsoft.com

# Reality private key — generate with: bash ../scripts/gen-cert.sh
REALITY_PRIVATE_KEY=your-private-key-here

# Reality short ID (8 hex chars) — generate with: openssl rand -hex 4
REALITY_SHORT_ID=your-short-id-here

# Keep a copy of the public key here for client setup reference
# REALITY_PUBLIC_KEY=your-public-key-here
