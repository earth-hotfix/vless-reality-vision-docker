# VLESS + Reality + Vision Client Configuration

# Server public IP or hostname
SERVER_IP=your-server-ip-here

# Server listening port (must match server XRAY_PORT)
SERVER_PORT=443

# VLESS user UUID (must match server UUID)
UUID=your-uuid-here

# Reality SNI domain (must match server SNI_DOMAIN)
SNI_DOMAIN=www.microsoft.com

# Reality public key (from gen-cert.sh output)
REALITY_PUBLIC_KEY=your-public-key-here

# Reality short ID (must match server REALITY_SHORT_ID)
REALITY_SHORT_ID=your-short-id-here

# Local SOCKS5 proxy port (bound to 127.0.0.1 by default)
SOCKS_PORT=1080
